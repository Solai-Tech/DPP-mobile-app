# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local — it is already in .gitignore

SAVE_CHAT_URL=https://solai.se/dppx/get-chats/
FLOWISE_SOLAI_ID=your-solai-chatflow-id
FLOWISE_DEMO_ID=your-demo-chatflow-id
FLOWISE_DEFAULT_ID=your-default-chatflow-id

# DPP PCB Analysis API (register client at DPP admin -> External API Clients)
DPP_API_URL=https://solai.se/dppx/api
DPP_CLIENT_ID=your-dpp-client-id
DPP_CLIENT_SECRET=your-dpp-client-secret

# Android release signing (used in android/gradle.properties)
RELEASE_STORE_PASSWORD=your-release-store-password
RELEASE_KEY_PASSWORD=your-release-key-password
